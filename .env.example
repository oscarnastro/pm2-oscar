PORT=3003
SESSION_SECRET=changeme_super_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
JWT_SECRET=changeme_jwt_secret

# Push notifications (PWA) – genera le chiavi con: npx web-push generate-vapid-keys
VAPID_EMAIL=admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Restart loop detection – notifica push se un processo supera N restart in X ms
RESTART_LOOP_THRESHOLD=5
RESTART_LOOP_WINDOW_MS=60000

# Invia notifica push anche per restart manuali riusciti (true/false)
NOTIFY_ON_RESTART=false
